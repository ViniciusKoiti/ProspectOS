@startuml
!theme cerulean-outline
title Arquitetura MCP Chain - Intelligent Lead Discovery

actor Usuario as "SDR/Usuario"
participant Controller as "LeadDiscoveryController"
participant Orchestrator as "MCPChainOrchestrator"

box "MCP Client & AI" #LightGreen
    participant MCP as "MCPClient"
    participant AI as "OpenAI/Claude\nGPT-4/Sonnet"
end box

box "Chain Steps (Sequential)" #LightBlue
    participant Analyzer as "MCPQueryAnalyzer"
    participant Decider as "MCPStrategyDecider"
    participant Executor as "MCPParallelExecutor"
    participant CrossRef as "MCPCrossReferencer"
    participant Quality as "MCPQualityFilter"
    participant Learning as "MCPLearningEngine"
end box

box "Data Sources (Parallel)" #Orange
    participant LinkedIn as "LinkedInSource"
    participant CNPJ as "CNPJSource"
    participant Crunchbase as "CrunchbaseSource"
    participant Vector as "VectorSource"
end box

database LearnDB as "Strategy Performance\nDatabase"

Usuario -> Controller: POST /api/leads/discover\n{"query": "CTOs fintech funding", "limit": 10}
Controller -> Orchestrator: discoverWithChain(request)

note over Orchestrator #AAFFAA
    **VANTAGEM: Workflow Inteligente**
    - Análise de query com IA
    - Decisão dinâmica de estratégia
    - Execução paralela otimizada
    - Cross-referência automática
    - Learning contínuo
end note

== STEP 1: Query Analysis ==
Orchestrator -> Analyzer: execute(context)
Analyzer -> MCP: analyzeQuery(prompt)
MCP -> AI: "Analyze: 'CTOs fintech funding'\nExtract: intent, industry, location, role..."
AI -> MCP: QueryAnalysis JSON\n{intent:"find", industry:"fintech", role:"CTO", timing:"recent_funding"}
MCP -> Analyzer: QueryAnalysis
Analyzer -> Orchestrator: context.withAnalysis()

== STEP 2: Strategy Decision ==
Orchestrator -> Decider: execute(context)
Decider -> MCP: decideStrategy(analysis, availableSources)
MCP -> AI: "Best sources for fintech CTOs with recent funding?\nOptions: linkedin, cnpj, crunchbase, vector..."
AI -> MCP: DiscoveryStrategy JSON\n{primary:"crunchbase", parallel:["linkedin","cnpj"], mode:"hybrid"}
MCP -> Decider: DiscoveryStrategy
Decider -> Orchestrator: context.withStrategy()

== STEP 3: Parallel Execution ==
Orchestrator -> Executor: execute(context)

note over Executor #AAFFAA
    **Execução Paralela Inteligente**
    CompletableFuture.allOf()
    Tempo: ~8s vs 45s sequencial
end note

par Parallel Execution
    Executor -> Crunchbase: searchFunding(query)
    Crunchbase -> Executor: List<FintechStartup>
else
    Executor -> LinkedIn: searchCTOs(companies)
    LinkedIn -> Executor: List<CTOProfile>
else
    Executor -> CNPJ: validateBrazilianCompanies(names)
    CNPJ -> Executor: List<CompanyValidation>
else
    Executor -> Vector: findSimilarCompanies(context)
    Vector -> Executor: List<SimilarCompany>
end

Executor -> Orchestrator: context.withSourceResults()

== STEP 4: Cross Reference ==
Orchestrator -> CrossRef: execute(context)
CrossRef -> MCP: crossReference(multiSourceData)
MCP -> AI: "Merge data:\n- Startup 'FinPay' (Crunchbase)\n- CTO 'João Silva' (LinkedIn)\n- CNPJ valid (CNPJ.ws)\nCreate enriched lead..."
AI -> MCP: CrossReferenceResult\n{consolidated_leads:[{company, contacts, confidence:0.92, timing_signals}]}
MCP -> CrossRef: CrossReferenceResult
CrossRef -> Orchestrator: context.withCrossReference()

== STEP 5: Quality Assessment ==
Orchestrator -> Quality: execute(context)
Quality -> MCP: assessQuality(leads, icp)
MCP -> AI: "Rate leads vs ICP:\nTarget: Fintech CTOs, Series A+\nLeads: [{FinPay, João Silva, funding:2M, 2weeks ago}]\nScore 0-100..."
AI -> MCP: QualityAssessment\n{filtered_leads:[{score:92, icp_match:95%, timing:98%}]}
MCP -> Quality: QualityAssessment
Quality -> Orchestrator: context.withQuality()

== STEP 6: Learning Engine ==
Orchestrator -> Learning: execute(context)
Learning -> LearnDB: save(StrategyPerformance)

note over LearnDB
    Stores:
    - Query pattern
    - Strategy used
    - Source performance
    - Final quality score
    - Execution time
end note

Learning -> MCP: optimizeStrategy(historicalData, currentQuery)
MCP -> AI: "Historical performance:\n- Fintech queries: Crunchbase+LinkedIn = 94% success\n- Funding timing: High conversion\nOptimize for next similar query..."
AI -> MCP: StrategyOptimization\n{next_strategy:"same", add_sources:["angellist"], confidence_threshold:0.85}
MCP -> Learning: StrategyOptimization
Learning -> Orchestrator: context.withOptimization()

Orchestrator -> Controller: LeadSearchResponse\n{leads:[{score:92, approach:"funding_timing"}], quality:HIGH}
Controller -> Usuario: High-Quality JSON Response\n[{"company": "FinPay", "cto": "João Silva", "score": 92, "timing": "funded 2 weeks ago"}]

note over Usuario #AAFFAA
    **RESULTADO SUPERIOR:**
    ⏱️ Tempo: ~8s (vs 45s)
    🎯 Qualidade: ~92% relevantes (vs 60%)
    🔗 Cross-ref: Automático e inteligente
    📈 Learning: Melhoria contínua
    💰 ROI: 5x melhor conversão
end note

@enduml
