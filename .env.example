# ==============================================
# ProspectOS Environment Configuration Example
# ==============================================
# Copy this file to .env and fill with your actual values
# Never commit .env with real secrets.
# Legend:
# - REQUIRED: needed for selected profile/feature
# - OPTIONAL: can stay empty when feature is disabled

# ==============================================
# AI PROVIDERS CONFIGURATION
# ==============================================

# OpenAI Configuration (OPTIONAL)
SPRING_AI_OPENAI_API_KEY=sk-your-openai-api-key-here
SPRING_AI_OPENAI_CHAT_MODEL=gpt-4
SPRING_AI_OPENAI_CHAT_OPTIONS_TEMPERATURE=0.7
SPRING_AI_OPENAI_CHAT_OPTIONS_MAX_TOKENS=2048

# Anthropic Claude Configuration (OPTIONAL)
SPRING_AI_ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
SPRING_AI_ANTHROPIC_CLAUDE_MODEL=claude-3-sonnet-20240229

# Groq Configuration (OPTIONAL)
PROSPECTOS_AI_GROQ_API_KEY=gsk-your-groq-api-key-here
PROSPECTOS_AI_GROQ_BASE_URL=https://api.groq.com/openai
PROSPECTOS_AI_GROQ_MODEL=llama-3.1-8b-instant
PROSPECTOS_AI_ACTIVE_PROVIDERS=openai,anthropic

# ==============================================
# APPLICATION CONFIGURATION
# ==============================================

# Active Profile (REQUIRED: development, test, production)
SPRING_PROFILES_ACTIVE=development

# Application Port (OPTIONAL)
SERVER_PORT=8080

# Logging Level (OPTIONAL)
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_DEV_PROSPECTOS=DEBUG
LOGGING_LEVEL_DEV_PROSPECTOS_AI=DEBUG

# Troubleshooting (OPTIONAL - enable only while debugging startup/config)
# DEBUG=true
# DOTENV_DEBUG=true
# PROSPECTOS_AI_ENABLED=true
# SCRAPER_AI_ENABLED=true
# LOGGING_LEVEL_DEV_PROSPECTOS_CONFIG=DEBUG
# LOGGING_LEVEL_DEV_PROSPECTOS_AI_CONFIG=DEBUG
# LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_BOOT_AUTOCONFIGURE=DEBUG
# LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_BOOT_CONTEXT_CONFIG=DEBUG
# LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_BEANS_FACTORY_SUPPORT=DEBUG

# ==============================================
# DATABASE CONFIGURATION
# ==============================================

# PostgreSQL Database (RECOMMENDED for development and production-like validation)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/prospectos
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_DATASOURCE_USERNAME=prospectos
SPRING_DATASOURCE_PASSWORD=prospectos123

# JPA Configuration (OPTIONAL)
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# MCP (OPTIONAL - enable only when you want the MCP surface in the current environment)
SPRING_AI_MCP_SERVER_ENABLED=false
SPRING_AI_MCP_SERVER_SECURITY_ENABLED=true
SPRING_AI_MCP_SERVER_SECURITY_API_KEY_HEADER=X-MCP-API-KEY
PROSPECTOS_MCP_MOCK_RUNTIME_ENABLED=false
MANAGEMENT_ENDPOINT_HEALTH_GROUP_MCP_INCLUDE=mcpServer

# ==============================================
# EXTERNAL SERVICES CONFIGURATION
# ==============================================

# Web Scraping Service (OPTIONAL)
SCRAPER_SERVICE_URL=http://localhost:3000
SCRAPER_SERVICE_TIMEOUT=30000

# Amazon Location Service (OPTIONAL - for source amazon-location)
PROSPECTOS_LEADS_AMAZON_LOCATION_ENABLED=false
PROSPECTOS_LEADS_AMAZON_LOCATION_REGION=us-east-1
PROSPECTOS_LEADS_AMAZON_LOCATION_API_KEY=
PROSPECTOS_LEADS_AMAZON_LOCATION_LANGUAGE=pt-BR
PROSPECTOS_LEADS_AMAZON_LOCATION_INTENDED_USE=SingleUse
PROSPECTOS_LEADS_AMAZON_LOCATION_MAX_RESULTS=20
PROSPECTOS_LEADS_AMAZON_LOCATION_INCLUDE_COUNTRIES=BRA

# Google Places Service (OPTIONAL - for source google-places)
PROSPECTOS_LEADS_GOOGLE_PLACES_ENABLED=false
PROSPECTOS_LEADS_GOOGLE_PLACES_API_KEY=
PROSPECTOS_LEADS_GOOGLE_PLACES_LANGUAGE_CODE=pt-BR
PROSPECTOS_LEADS_GOOGLE_PLACES_MAX_RESULTS=20

# Google PageSpeed Service (OPTIONAL - for prospect website technical audit)
PROSPECTOS_PROSPECT_PAGESPEED_ENABLED=false
PROSPECTOS_PROSPECT_PAGESPEED_API_KEY=
PROSPECTOS_PROSPECT_PAGESPEED_BASE_URL=https://www.googleapis.com/pagespeedonline/v5/runPagespeed
PROSPECTOS_PROSPECT_PAGESPEED_STRATEGY=mobile
PROSPECTOS_PROSPECT_PAGESPEED_LOCALE=pt-BR
PROSPECTOS_PROSPECT_PAGESPEED_TIMEOUT=30s

# Apify Google Maps Scraper (OPTIONAL - for source apify)
PROSPECTOS_LEADS_APIFY_ENABLED=false
PROSPECTOS_LEADS_APIFY_API_TOKEN=
PROSPECTOS_LEADS_APIFY_ACTOR_ID=scraper-engine~google-maps-scraper
PROSPECTOS_LEADS_APIFY_BASE_URL=https://api.apify.com
PROSPECTOS_LEADS_APIFY_TIMEOUT=45s
PROSPECTOS_LEADS_APIFY_USE_PROXY=false

# News API (OPTIONAL)
NEWS_API_KEY=your-news-api-key-here
NEWS_API_URL=https://newsapi.org/v2

# ==============================================
# SECURITY CONFIGURATION
# ==============================================

# JWT Configuration (OPTIONAL, REQUIRED if JWT is enabled)
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRATION=86400000

# CORS Configuration (OPTIONAL)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# ==============================================
# MONITORING AND OBSERVABILITY
# ==============================================

# Actuator Configuration
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when_authorized

# Metrics Configuration
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true

# ==============================================
# AI BEHAVIOR CONFIGURATION
# ==============================================

# Mock AI Responses (for testing)
MOCK_AI_RESPONSES_ENABLED=false
MOCK_AI_RESPONSE_DELAY=500

# AI Request Timeouts (in milliseconds)
AI_REQUEST_TIMEOUT=30000
AI_MAX_RETRIES=3

# AI Provider Priority (comma-separated)
AI_PROVIDER_PRIORITY=openai,anthropic

# ==============================================
# FEATURE FLAGS
# ==============================================

# Enable/Disable Features
FEATURE_AI_ENRICHMENT_ENABLED=true
FEATURE_AUTO_SCORING_ENABLED=true
FEATURE_OUTREACH_GENERATION_ENABLED=true
FEATURE_SIGNAL_DETECTION_ENABLED=true

# ==============================================
# DEVELOPMENT TOOLS
# ==============================================

# Spring DevTools
SPRING_DEVTOOLS_RESTART_ENABLED=true
SPRING_DEVTOOLS_LIVERELOAD_ENABLED=true



